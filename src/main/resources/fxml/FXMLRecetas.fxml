<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.sistemagestionpizzeria.controller.FXMLRecetasController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label styleClass="title-header" text="Gestión de Recetas" />
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="white-card">
               <children>
                  <Label styleClass="label-standard" text="Seleccionar Producto:" />
                  <ComboBox fx:id="cbProductos" onAction="#seleccionarProducto" prefWidth="300.0" promptText="--- Seleccione un producto ---" />
                  <Separator orientation="VERTICAL" />
                  <Label fx:id="lblCodigoProducto" styleClass="label-standard" text="Código: ---" />
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </HBox>
            
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Panel Izquierdo: Formulario de Ingrediente -->
                  <VBox prefWidth="300.0" spacing="15.0" styleClass="white-card">
                     <children>
                        <Label styleClass="title-sub" text="Agregar/Editar Ingrediente" />
                        <VBox spacing="5.0">
                           <children>
                              <Label styleClass="label-standard" text="Insumo:" />
                              <ComboBox fx:id="cbInsumos" prefWidth="270.0" promptText="Seleccionar insumo" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label styleClass="label-standard" text="Cantidad Requerida:" />
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <TextField fx:id="tfCantidad" prefWidth="150.0" promptText="0.00" />
                                    <Label fx:id="lblUnidad" styleClass="label-standard" text="---" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <HBox spacing="10.0">
                           <children>
                              <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#clicBtnAgregar" prefWidth="130.0" styleClass="btn-success" text="Agregar" />
                              <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#clicBtnLimpiar" prefWidth="130.0" styleClass="btn-primary" text="Limpiar" />
                           </children>
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
                  
                  <!-- Panel Derecho: Tabla de Receta -->
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="title-sub" text="Ingredientes de la Receta" />
                        <TableView fx:id="tvReceta" prefHeight="400.0">
                          <columns>
                            <TableColumn fx:id="colInsumo" prefWidth="200.0" text="Insumo" />
                            <TableColumn fx:id="colCantidad" prefWidth="100.0" text="Cantidad" />
                            <TableColumn fx:id="colUnidad" prefWidth="100.0" text="Unidad" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#clicBtnEliminar" styleClass="btn-danger" text="Eliminar Ingrediente" />
                              <Button fx:id="btnGuardarReceta" mnemonicParsing="false" onAction="#clicBtnGuardarReceta" styleClass="btn-info" text="Guardar Cambios de Receta" />
                           </children>
                           <padding>
                              <Insets top="10.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
