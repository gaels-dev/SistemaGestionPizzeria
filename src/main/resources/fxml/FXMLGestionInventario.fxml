<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="650.0" prefWidth="1000.0" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.sistemagestionpizzeria.controller.FXMLGestionInventarioController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label styleClass="title-header" text="Validación de Inventarios (Insumos)" />
               </children>
            </HBox>
            
            <VBox spacing="10.0" styleClass="white-card" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <TextField fx:id="tfFiltro" prefWidth="300.0" promptText="Filtrar por nombre o código..." />
                        <Button fx:id="btnRefrescar" mnemonicParsing="false" onAction="#clicBtnRefrescar" styleClass="btn-primary" text="Refrescar Datos" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="tvInventario" editable="true" prefHeight="400.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colCodigo" prefWidth="100.0" text="Código" />
                      <TableColumn fx:id="colInsumo" prefWidth="250.0" text="Nombre del Insumo" />
                      <TableColumn fx:id="colUnidad" prefWidth="80.0" text="Unidad" />
                      <TableColumn fx:id="colCantSistema" prefWidth="120.0" text="Stock Sistema" />
                      <TableColumn fx:id="colCantReal" prefWidth="120.0" text="Conteo Físico" />
                      <TableColumn fx:id="colDiferencia" prefWidth="120.0" text="Diferencia" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="label-standard" text="Notas / Observaciones de la validación:" />
                        <javafx.scene.control.TextArea fx:id="taNotas" prefHeight="80.0" promptText="Escriba aquí cualquier observación sobre mermas, daños o hallazgos..." wrapText="true" />
                     </children>
                  </VBox>
                  
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Label styleClass="label-standard" text="* Haga doble clic en 'Conteo Físico' para editar la cantidad real." textFill="#666666" />
                        <AnchorPane HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnAjustar" mnemonicParsing="false" onAction="#clicBtnAjustar" styleClass="btn-success" text="Aplicar Ajustes de Inventario" />
                     </children>
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
