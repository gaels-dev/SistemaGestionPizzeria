<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="570.0" prefWidth="1280.0" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.sistemagestionpizzeria.controller.FXMLGestionUsuariosController">
   <children>
      <VBox layoutX="179.0" layoutY="14.0" prefHeight="511.0" prefWidth="923.0" AnchorPane.bottomAnchor="13.0" AnchorPane.leftAnchor="179.0" AnchorPane.rightAnchor="178.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="TOP_CENTER" prefHeight="31.0" prefWidth="791.0">
               <children>
                  <ComboBox fx:id="cbTipoBusqueda" prefHeight="25.0" prefWidth="658.0" />
               </children>
            </HBox>
            <HBox prefHeight="48.0" prefWidth="791.0" spacing="20.0">
               <children>
                  <TextField fx:id="tfBusqueda" prefHeight="25.0" prefWidth="230.0" promptText="Buscar usuario ..." />
                  <Button mnemonicParsing="false" onAction="#buscarUsuario" prefHeight="25.0" prefWidth="69.0" styleClass="btn-primary" text="Buscar">
                  </Button>
                  <Separator opacity="0.0" prefHeight="7.0" prefWidth="326.0" />
                  <Button mnemonicParsing="false" onAction="#crearUsuario" styleClass="btn-success" text="+ Nuevo">
                  </Button>
                  <Button mnemonicParsing="false" onAction="#editarUsuario" prefHeight="25.0" prefWidth="60.0" styleClass="btn-info" text="Editar" />
                  <Button mnemonicParsing="false" onAction="#eliminarUsuario" prefHeight="25.0" prefWidth="65.0" styleClass="btn-danger" text="Eliminar" />
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </HBox>
            <TableView fx:id="tvUsuarios" prefHeight="415.0" prefWidth="923.0">
              <columns>
                <TableColumn fx:id="colNombre" editable="false" prefWidth="160.0" text="Nombre" />
                <TableColumn fx:id="colTelefono" editable="false" minWidth="1.0" prefWidth="103.0" text="Teléfono" />
                  <TableColumn fx:id="colEmail" minWidth="0.0" prefWidth="92.0" text="Email" />
                  <TableColumn fx:id="colDireccion" prefWidth="122.0" text="Dirección" />
                  <TableColumn fx:id="colCP" prefWidth="67.0" text="CP" />
                  <TableColumn fx:id="colCiudad" prefWidth="75.0" text="Ciudad" />
                  <TableColumn fx:id="colTipo" prefWidth="75.0" text="Tipo" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="BOTTOM_RIGHT" prefHeight="46.0" prefWidth="791.0">
               <children>
                  <Button fx:id="btnSalir" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#salirUsuarios" prefHeight="25.0" prefWidth="68.0" style="-fx-background-color: #222; -fx-font-weight: bold;" text="Salir" textFill="WHITE" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
