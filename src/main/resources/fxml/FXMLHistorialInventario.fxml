<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="650.0" prefWidth="1100.0" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.sistemagestionpizzeria.controller.FXMLHistorialInventarioController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label styleClass="title-header" text="Historial de Validaciones de Inventario" />
            
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Panel Izquierdo: Lista de Registros -->
                  <VBox prefWidth="450.0" spacing="10.0" styleClass="white-card">
                     <children>
                        <Label styleClass="title-sub" text="Registros" />
                        <TableView fx:id="tvHistorial" onMouseClicked="#seleccionarRegistro" prefHeight="450.0">
                          <columns>
                            <TableColumn fx:id="colFecha" prefWidth="160.0" text="Fecha" />
                            <TableColumn fx:id="colEmpleado" prefWidth="240.0" text="Empleado" />
                          </columns>
                        </TableView>
                        <Button fx:id="btnRefrescar" mnemonicParsing="false" onAction="#clicBtnRefrescar" styleClass="btn-primary" text="Refrescar Lista" />
                     </children>
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                  </VBox>
                  
                  <!-- Panel Derecho: Detalles del Registro Seleccionado -->
                  <VBox spacing="10.0" styleClass="white-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label styleClass="title-sub" text="Detalles del Registro" />
                              <Separator orientation="VERTICAL" />
                              <Label fx:id="lblFechaSeleccionada" styleClass="label-standard" text="Fecha: ---" />
                           </children>
                        </HBox>
                        
                        <TableView fx:id="tvDetalles" prefHeight="400.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colCodigo" prefWidth="90.0" text="Código" />
                            <TableColumn fx:id="colInsumo" prefWidth="180.0" text="Insumo" />
                            <TableColumn fx:id="colCantSistema" prefWidth="100.0" text="Sistema" />
                            <TableColumn fx:id="colCantReal" prefWidth="100.0" text="Real" />
                            <TableColumn fx:id="colDiferencia" prefWidth="100.0" text="Diferencia" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button fx:id="btnExportarPDF" mnemonicParsing="false" onAction="#clicBtnExportarPDF" styleClass="btn-info" text="Exportar a PDF" />
                           </children>
                           <padding>
                              <Insets top="10.0" />
                           </padding>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
